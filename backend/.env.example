# Copy this file to backend/.env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql://seo_user:seo_password@localhost:5432/seo_analyzer

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenRouter (Gemini via OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# CORS (frontend URL — comma-separated for multiple origins)
CORS_ORIGINS=https://aftab-fastapi.duckdns.org,http://aftab-fastapi.duckdns.org,http://35.174.167.153,http://localhost:5173

# App
APP_NAME=SEO Page Analyzer
